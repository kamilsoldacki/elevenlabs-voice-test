# Jeśli agent wymaga autoryzacji przy tokenie WebRTC, ustaw klucz z https://elevenlabs.io/app/settings/api-keys
XI_API_KEY=

# Opcjonalnie nadpisz (domyślnie są wartości z Twojego linku talk-to)
# AGENT_ID=agent_2401kpdcfbczeznsr4bkmr97c7p1
# BRANCH_ID=agtbrch_7601kpdcfd0de3prknkcrzz1z04f

# Lokalny build testujący ścieżkę jak na Pages: npm run build && VITE_BASE_PATH=/nazwa-repo/ npm run preview
# VITE_BASE_PATH=/

# Wyłącz serwer tokenów przy dev (wtedy jak na GitHub Pages — tylko agentId w przeglądarce).
# VITE_DEV_USE_TOKEN_SERVER=false

# Domyślnie jak na https://kamilsoldacki.github.io/pjatk-march_workshops-2026/ — wyłącznie agentId (SDK sam pobiera token WebRTC).
# Włącz tylko jeśli musisz token z branch_id z przeglądarki:
# VITE_USE_BROWSER_TOKEN=true
# VITE_BRANCH_ID=agtbrch_7601kpdcfd0de3prknkcrzz1z04f

# Rzadko: wymuś WebSocket zamiast WebRTC (bez branch_id w URL SDK):
# VITE_USE_WEBSOCKET=true
